 libvmaf_sycl_filter_deps="libvmaf libvmaf_sycl libvpl"
 libvmaf_vulkan_filter_deps="libvmaf libvmaf_vulkan vulkan"
 vmaf_pre_filter_deps="libvmaf"
@@ -7405,6 +7406,8 @@ enabled libvmaf           && check_pkg_config libvmaf_hip "libvmaf >= 3.0.0" lib
 enabled libvmaf_metal     && require_pkg_config libvmaf "libvmaf >= 3.0.0" libvmaf.h vmaf_init &&
