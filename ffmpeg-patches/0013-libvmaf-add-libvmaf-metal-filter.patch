@@ -351,5 +351,6 @@ extern const FFFilter ff_vf_libplacebo;
 extern const FFFilter ff_vf_libvmaf;
 extern const FFFilter ff_vf_libvmaf_cuda;
+extern const FFFilter ff_vf_libvmaf_metal;
