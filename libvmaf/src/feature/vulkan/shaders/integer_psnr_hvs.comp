 *
 * Vulkan compute shader for the integer_psnr_hvs feature extractor.
 * Port of the CUDA twin (feature/cuda/integer_psnr_hvs_cuda.c +
 * feature/cuda/integer_psnr_hvs/psnr_hvs_score.cu) to GLSL, following
 * the psnr_hvs.comp design but reading raw integer samples (uint8 or
 * uint16) directly from the SSBO instead of float pre-normalised input.
 *
 * Reads raw packed uint samples (1 element per sample):
 *   8bpc  → low 8 bits of each uint element.
 *   10bpc → low 16 bits; integer value is the raw sample (0..1023).
 *   12bpc → low 16 bits; integer value is the raw sample (0..4095).
 * No host-side float normalisation is needed: the integer DCT operates
 * directly on the raw sample values, as the CPU path does.
 *
 * Design mirrors psnr_hvs.comp:
 *   - One workgroup per 8×8 block (step=7 sliding window).
 *   - 64 threads/WG for cooperative sample load into shared memory.
 *   - Thread 0 performs all per-block arithmetic (scalar DCT + masking)
 *     to match CPU's exact i,j summation order bit-for-bit.
 *   - Per-WG float partial written to partials_out[blk_y*num_blocks_x + blk_x].
 *
 * Specialization constants:
 *   0  BPC           bits per component (8, 10, 12)
 *   1  PLANE         0 = Y, 1 = Cb, 2 = Cr (selects CSF table)
 *   2  SUBGROUP_SIZE compile-time sizing (unused in serial path)
 *
 * Resource bindings:
 *   0: ref plane  (uint[], packed raw integer samples, row-major, no stride padding)
 *   1: dist plane (same convention)
 *   2: per-block float partials
 *
 * Host accumulates:
 *   score = sum(partials) / (num_blocks * 64) / samplemax²
 *   db    = 10 * log10(1 / score)
 * Combined: psnr_hvs = 0.8·Y + 0.1·(Cb + Cr) (in linear score domain).
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int BPC           = 8;
layout(constant_id = 1) const int PLANE         = 0;
layout(constant_id = 2) const int SUBGROUP_SIZE = 32;

const int WG_X    = 8;
const int WG_Y    = 8;
const int WG_SIZE = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

