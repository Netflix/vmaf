/* Copyright 2026 Lusoris and Claude (Anthropic)
 * SPDX-License-Identifier: BSD-3-Clause-Plus-Patent
 *
 * Vulkan compute shader for the integer VIF feature extractor.
 *
 * Direct port of libvmaf/src/feature/sycl/integer_vif_sycl.cpp's
 * `launch_vif_fused_impl` template specialised through a single
 * compile-time SCALE specialization-constant. Mirrors the SYCL
 * structure 1:1 so reviewers can do a side-by-side compare:
 *   Phase 1: cooperative tile load of ref/dis into shared memory
 *            (with mirror padding at frame borders);
 *   Phase 2: cooperative vertical convolution -> s_vert (5 or 7 ch);
 *   Phase 3: per-thread horizontal convolution + VIF stats
 *            + per-thread int64 accumulators + downsample;
 *   Phase 4: subgroup reduction, then cross-subgroup reduction in
 *            shared memory, then thread-0 atomic-add into the global
 *            per-workgroup accumulator SSBO.
 *
 * int64 representation
 * --------------------
 * GLSL has no native int64 atomics in vulkan1.3 core. We use
 * GL_EXT_shader_explicit_arithmetic_types_int64 to get `i64vec`
 * arithmetic for the per-thread + per-subgroup reductions, but write
 * each of the seven 56-byte accumulator fields PER WORKGROUP back to
 * global as a regular `int64_t` slot in an SSBO — no atomic add to a
 * single global counter is needed because every workgroup owns its
 * own slot. The CPU side reduces (sums) the per-workgroup slots after
 * the dispatch completes. This avoids both
 * VK_KHR_shader_atomic_int64 (optional capability, missing on
 * Mesa-NIR + lavapipe in some configs) and the float64 alternative.
 *
 * If GL_EXT_shader_explicit_arithmetic_types_int64 is rejected at
 * compile time on a target driver, the fallback is a uvec2-with-carry
 * representation; both compile to the same SPIR-V int64 intrinsics on
 * Mesa-NIR (Arc A380, RADV) and on AMDVLK / NVIDIA proprietary, but
 * the explicit-types form is dramatically more readable. The Vulkan
 * SDK glslc 2026.1 enables both extensions in vulkan1.3 mode by
 * default per its release notes.
 *
 * Specialization constants vs. runtime SCALE
 * ------------------------------------------
 * SYCL has 4 template specializations (SCALE = 0..3). Vulkan compute
 * shaders allow specialization constants which the C-side
 * `VkSpecializationInfo` resolves at pipeline-create time. We expose
 * SCALE as `layout(constant_id = 0) const int SCALE = 0;`. The C
 * side creates four pipeline objects, one per scale, sharing the
 * same SPIR-V module. Coefficient tables and shift parameters are
 * indexed by SCALE; the optimizer constant-folds the dead branches.
 *
 * The fused V+H path is the only path implemented here — it matches
 * the SYCL `vif_fused = true` branch. The separate vert/hori path
 * from SYCL was an Arc-A380 perf workaround; the Vulkan port skips
 * it (one less pipeline-pair to manage). If perf measurements call
 * for it, a follow-up PR can add it as a parallel `vif_separate.comp`.
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic               : require
#extension GL_KHR_shader_subgroup_basic                    : require
#extension GL_KHR_shader_subgroup_shuffle                  : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64   : require
#extension GL_EXT_shader_subgroup_extended_types_int64     : require
/* GL_EXT_shader_explicit_arithmetic_types_float64 is required for the
 * VIF g/sv_sq computation in double precision to match integer_vif.c's
 * `double g = sigma12 / (sigma1_sq + eps)` path exactly.  RTX 4090
 * and all Vulkan 1.3+ discrete GPUs expose shaderFloat64 (probed in
 * vmaf_vulkan_context_new; the backend refuses to init on devices that
 * don't expose it — see ADR-0492). */
#extension GL_EXT_shader_explicit_arithmetic_types_float64 : require

/* Workgroup geometry mirrors the SYCL fused kernel:
 *   local_size_x = 32  -> matches the subgroup size requirement
 *                          (Arc Xe-HPG natural SIMD32; RDNA wave32);
 *   local_size_y = 4   -> 32*4 = 128 threads per workgroup, which
 *                          keeps SLM occupancy good at scale 0.
 * The SYCL fused path uses (16,8) — same 128-thread total. We use
 * (32,4) so a single subgroup spans one full output row of the
 * workgroup, simplifying the horizontal convolution access pattern.
 */
layout(local_size_x = 32, local_size_y = 4, local_size_z = 1) in;

/* SCALE = 0..3, set per-pipeline via VkSpecializationInfo. */
layout(constant_id = 0) const int  SCALE = 0;
/* For SCALE == 0 only: the source bit depth (8/10/12/16). For
 * SCALE > 0 the input is the SCALE-1 reduction buffer (uint16
 * packed in uint32) and BPC is ignored. */
layout(constant_id = 1) const int  BPC   = 8;
/* SUBGROUP_SIZE pinned per-pipeline at create time when the device
 * exposes VK_EXT_subgroup_size_control. Default 32 matches Arc /
 * RDNA wave32 / NVIDIA warp; runtime falls back to whatever the
 * driver picks if the extension is absent. The shader does NOT
 * assume this constant equals gl_SubgroupSize at runtime — it is
 * informational only and used for compile-time array sizing. */
layout(constant_id = 2) const int  SUBGROUP_SIZE = 32;

/* ------------------------------------------------------------------
 * Per-scale tables (constant-folded after specialization).
 * Coefficients identical to vif_filter1d_table in
 * integer_vif_sycl.cpp (lines 70-76).
 * ------------------------------------------------------------------ */
const int VIF_NUM_SCALES        = 4;
const int VIF_FILTER_MAX_WIDTH  = 17;

/* Filter widths per scale: { 17, 9, 5, 3 } main filter,
 * { 9, 5, 3, 0 } reduction (next-scale) filter. Encoded as
 * if-ladders in FW()/FW_RD()/HALF_FW()/RD_START() below — see
 * comment there for the glslc 2026.1 -O workaround. */

const uint COEFF_S0[17] = uint[17](
    489u, 935u, 1640u, 2640u, 3896u, 5274u, 6547u, 7455u,
    7784u, 7455u, 6547u, 5274u, 3896u, 2640u, 1640u, 935u, 489u);
const uint COEFF_S1[17] = uint[17](
    1244u, 3663u, 7925u, 12590u, 14692u, 12590u, 7925u, 3663u, 1244u,
    0u,0u,0u,0u,0u,0u,0u,0u);
const uint COEFF_S2[17] = uint[17](
    3571u, 16004u, 26386u, 16004u, 3571u,
    0u,0u,0u,0u,0u,0u,0u,0u,0u,0u,0u,0u);
const uint COEFF_S3[17] = uint[17](
    10904u, 43728u, 10904u,
    0u,0u,0u,0u,0u,0u,0u,0u,0u,0u,0u,0u,0u,0u);

uint coeff(int idx) {
    if (SCALE == 0) return COEFF_S0[idx];
    if (SCALE == 1) return COEFF_S1[idx];
    if (SCALE == 2) return COEFF_S2[idx];
    return COEFF_S3[idx];
}
/* For the reduction filter (next-scale), we consume the SCALE+1
 * row of the same table. SCALE==3 has FW_RD==0 so this is never
 * indexed there. */
uint coeff_rd(int idx) {
    if (SCALE == 0) return COEFF_S1[idx];
    if (SCALE == 1) return COEFF_S2[idx];
    if (SCALE == 2) return COEFF_S3[idx];
    return 0u;  /* unreachable when FW_RD == 0 */
}

const int64_t SIGMA_NSQ = 131072L;   /* 2 * 65536, matches SYCL */
const int     LOG2_LUT_SIZE = 32768;

/* ------------------------------------------------------------------
 * Resource bindings.
 *   binding 0: ref input plane.
 *     SCALE == 0 -> uint8 packed in uint32 (4 px / word) when BPC==8,
 *                   uint16 packed in uint32 (2 px / word) when BPC>8;
 *     SCALE  > 0 -> uint16 stored in lower half of each uint32 word
 *                   (the rd buffer written by the previous scale).
 *   binding 1: dis input plane (same layout as binding 0).
 *   binding 2: rd_ref (downsampled ref output for SCALE+1; SSBO).
 *              Unused when SCALE == 3 (FW_RD == 0).
 *   binding 3: rd_dis (downsampled dis output for SCALE+1; SSBO).
 *   binding 4: log2_lut (uint32[32768], pre-uploaded by host).
 *   binding 5: per-workgroup accumulator output —
 *              [workgroup_count][7] int64_t row-major.
 * ------------------------------------------------------------------ */
layout(set = 0, binding = 0, std430) readonly buffer RefIn  { uint pixels[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer DisIn  { uint pixels[]; } dis_in;
layout(set = 0, binding = 2, std430)          buffer RdRef  { uint rd[];     } rd_ref_out;
layout(set = 0, binding = 3, std430)          buffer RdDis  { uint rd[];     } rd_dis_out;
layout(set = 0, binding = 4, std430) readonly buffer Log2Lut{ uint lut[];    } log2_lut;
layout(set = 0, binding = 5, std430)          buffer Accum  { int64_t v[];   } accum_out;

layout(push_constant) uniform Params {
    uint  width;          /* current scale's plane width  in pixels */
    uint  height;         /* current scale's plane height in pixels */
    uint  src_stride;     /* row stride in BYTES (not uint32 words) */
    float vif_enhn_gain_limit;
    uint  num_workgroups_x;  /* gl_NumWorkGroups.x snapshotted host-side */
} pc;

/* ------------------------------------------------------------------
 * Workgroup constants.
 * ------------------------------------------------------------------ */
const int WG_X      = 32;
const int WG_Y      = 4;
const int WG_SIZE   = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;  /* upper bound; runtime uses fewer */

/* HALF_FW per scale. Implemented as if-ladders rather than indexing
 * into a const array with a spec-constant key — `OpSpecConstantOp`
 * over array constants tickles a glslc 2026.1 -O optimizer bug
 * (`spirv-opt` rejects the resulting chain). The if-ladders
 * constant-fold cleanly under specialization. */
int FW() {
    if (SCALE == 0) return 17;
    if (SCALE == 1) return 9;
    if (SCALE == 2) return 5;
    return 3;
}
int HALF_FW() {
    if (SCALE == 0) return 8;
    if (SCALE == 1) return 4;
    if (SCALE == 2) return 2;
    return 1;
}
int FW_RD() {
    if (SCALE == 0) return 9;
    if (SCALE == 1) return 5;
    if (SCALE == 2) return 3;
    return 0;
}
int HALF_FW_RD() {
    if (SCALE == 0) return 4;
    if (SCALE == 1) return 2;
    if (SCALE == 2) return 1;
    return 0;
}
int RD_START() {
    if (SCALE == 0) return 4;  /* (17-9)/2 */
    if (SCALE == 1) return 2;  /* (9-5)/2  */
    if (SCALE == 2) return 1;  /* (5-3)/2  */
    return 0;
}

/* Tile dimensions: 17-tap filter + WG_X=32 -> TILE_W = 32 + 16 = 48
 * at scale 0. We dimension all SLM allocations to the worst case
 * (scale 0) to keep the shader-source single-binary. The SPIR-V
 * optimizer drops unused SLM space at SCALE>0 because the loop
 * bounds are constant-folded. */
const int TILE_H_MAX = WG_Y + 17 - 1;   /* 4 + 16 = 20 */
const int TILE_W_MAX = WG_X + 17 - 1;   /* 32 + 16 = 48 */

shared uint  s_ref[TILE_H_MAX * TILE_W_MAX];
shared uint  s_dis[TILE_H_MAX * TILE_W_MAX];

/* Vertical-pass intermediates, 5 or 7 channels per output cell.
 * VERT_TOTAL_MAX = WG_Y * TILE_W_MAX. */
const int N_CH_MAX     = 7;
const int VERT_TOTAL_MAX = WG_Y * TILE_W_MAX;
shared uint  s_vert[N_CH_MAX * VERT_TOTAL_MAX];

/* Cross-subgroup reduction scratch (7 fields x MAX_SUBGROUPS).
 * MAX_SUBGROUPS = WG_SIZE = 128 here, but the host-side pipeline
 * pins reqd_subgroup_size when the device supports it, so the
 * effective number is WG_SIZE / SUBGROUP_SIZE. */
const int ACCUM_FIELDS = 7;
shared int64_t s_lmem[ACCUM_FIELDS * MAX_SUBGROUPS];

/* NVIDIA 595.71.05 at Vulkan API 1.4 has been observed to produce
 * non-deterministic SCALE=2 VIF accumulator values through
 * subgroupAdd(int64_t), even after stronger shared-memory fences
 * (research-0090 / ADR-0269 Phase-3b). Use explicit lane exchanges
 * plus plain int64 adds so the driver avoids its int64 subgroup-add
 * lowering path. */
int64_t reduce_i64_subgroup(int64_t v) {
    int64_t r = v;
    for (uint mask = 1u; mask < gl_SubgroupSize; mask <<= 1u) {
        r += subgroupShuffleXor(r, mask);
    }
    return r;
}

/* ------------------------------------------------------------------
 * Helpers (mirror dev_mirror / dev_get_best16_from32 / from64
 * in integer_vif_sycl.cpp).
 * ------------------------------------------------------------------ */
int dev_mirror(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * (sup - 1) - idx;
    return idx;
}

uint dev_best16_from32(uint val, out int exp_out) {
    if (val == 0u) { exp_out = 0; return 0u; }
    int msb = 31;
    while (msb >= 0 && ((val >> uint(msb)) & 1u) == 0u) msb--;
    int k = msb - 15;
    if (k < 0) k = 0;
    val = val >> uint(k);
    exp_out = -k;
    return val & 0xFFFFu;
}

uint dev_best16_from64(uint64_t val, out int exp_out) {
    if (val == 0UL) { exp_out = 0; return 0u; }
    int  clz = 0;
    uint64_t tmp = val;
    if ((tmp >> 32) == 0UL) { clz += 32; tmp = tmp << 32; }
    if ((tmp >> 48) == 0UL) { clz += 16; tmp = tmp << 16; }
    if ((tmp >> 56) == 0UL) { clz += 8;  tmp = tmp << 8;  }
    if ((tmp >> 60) == 0UL) { clz += 4;  tmp = tmp << 4;  }
    if ((tmp >> 62) == 0UL) { clz += 2;  tmp = tmp << 2;  }
    if ((tmp >> 63) == 0UL) { clz += 1; }

    int k = clz;
    if (k > 48) {
        val = val << uint(k - 48);
        exp_out = k - 48;
    } else if (k < 47) {
        val = val >> uint(48 - k);
        exp_out = -(48 - k);
    } else {
        exp_out = 0;
        if ((val >> 16) != 0UL) {
            val = val >> 1;
            exp_out = -1;
        }
    }
    return uint(val) & 0xFFFFu;
}

/* Read a single source pixel from the input plane.
 *   SCALE == 0:  unpack from the bpc-specific packed plane;
 *   SCALE  > 0:  read uint16 from rd buffer (SCALE-1 output).
 * Caller guarantees (x,y) is in-bounds (mirror is applied before
 * the call site). */
uint read_src(uint which, int y, int x) {
    if (SCALE == 0) {
        if (BPC <= 8) {
            uint row = uint(y) * (pc.src_stride >> 2);
            uint word = (which == 0u) ? ref_in.pixels[row + (uint(x) >> 2)]
                                      : dis_in.pixels[row + (uint(x) >> 2)];
            uint sh = (uint(x) & 3u) * 8u;
            return (word >> sh) & 0xFFu;
        } else {
            uint row = uint(y) * (pc.src_stride >> 2);
            uint word = (which == 0u) ? ref_in.pixels[row + (uint(x) >> 1)]
                                      : dis_in.pixels[row + (uint(x) >> 1)];
            uint sh = (uint(x) & 1u) * 16u;
            return (word >> sh) & 0xFFFFu;
        }
    } else {
        /* rd buffer: one uint per pixel, lower 16 bits are payload. */
        uint row = uint(y) * pc.width;
        uint word = (which == 0u) ? ref_in.pixels[row + uint(x)]
                                  : dis_in.pixels[row + uint(x)];
        return word & 0xFFFFu;
    }
}

/* ------------------------------------------------------------------
 * main()
 * ------------------------------------------------------------------ */
void main()
{
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    int lx = int(gl_LocalInvocationID.x);
    int ly = int(gl_LocalInvocationID.y);
    uint lid = uint(ly * WG_X + lx);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    int half_v = HALF_FW();
    int half_h = HALF_FW();        /* symmetric H == V */
    int fw_v   = FW();
    int fw_h   = FW();
    int fw_rd  = FW_RD();
    int rd_st  = RD_START();
    int tile_h = WG_Y + fw_v - 1;
    int tile_w = WG_X + fw_h - 1;

    /* Quantization parameters (mirror the SYCL ones). */
    uint shift_vp;
    uint add_round_vp;
    uint shift_vp_sq;
    uint add_round_vp_sq;
    if (SCALE == 0) {
        shift_vp        = uint(BPC);
        add_round_vp    = 1u << uint(BPC - 1);
        shift_vp_sq     = uint((BPC - 8) * 2);
        add_round_vp_sq = (BPC == 8) ? 0u : (1u << (shift_vp_sq - 1u));
    } else {
        shift_vp        = 16u;
        add_round_vp    = 32768u;
        shift_vp_sq     = 16u;
        add_round_vp_sq = 32768u;
    }

    /* ============================================================
     * Phase 1: cooperative tile load with mirror padding.
     * ============================================================ */
    int tile_oy = int(gl_WorkGroupID.y) * WG_Y - half_v;
    int tile_ox = int(gl_WorkGroupID.x) * WG_X - half_h;
    int tile_elems = tile_h * tile_w;

    bool interior =
        (tile_oy >= 0) && (tile_oy + tile_h <= int(pc.height)) &&
        (tile_ox >= 0) && (tile_ox + tile_w <= int(pc.width));

    for (int i = int(lid); i < tile_elems; i += WG_SIZE) {
        int tr = i / tile_w;
        int tc = i - tr * tile_w;
        int py = tile_oy + tr;
        int px = tile_ox + tc;
        if (!interior) {
            py = dev_mirror(py, int(pc.height));
            px = dev_mirror(px, int(pc.width));
        }
        s_ref[tr * tile_w + tc] = read_src(0u, py, px);
        s_dis[tr * tile_w + tc] = read_src(1u, py, px);
    }
    /* Shared-memory release-acquire: pair the cooperative writes to
     * s_ref / s_dis with Phase-2's reads. Vulkan 1.4 NVIDIA defaults
     * to a stricter memory model than 1.3 — a bare barrier() is no
     * longer sufficient on this driver to publish shared writes
     * across subgroups. See research-0089 + ADR-0269 status update. */
    memoryBarrierShared();
    barrier();

    /* ============================================================
     * Phase 2: cooperative vertical convolution -> s_vert.
     * ============================================================ */
    int n_ch = (fw_rd > 0) ? 7 : 5;
    int vert_total = WG_Y * tile_w;

    for (int i = int(lid); i < vert_total; i += WG_SIZE) {
        int r = i / tile_w;
        int c = i - r * tile_w;

        uint a_mu1 = 0u, a_mu2 = 0u;
        uint64_t a_ref = 0UL, a_dis = 0UL, a_rd_x = 0UL;
        uint a_ref_rd = 0u, a_dis_rd = 0u;

        for (int fi = 0; fi < fw_v; fi++) {
            int sidx = (r + fi) * tile_w + c;
            uint rv = s_ref[sidx];
            uint dv = s_dis[sidx];
            uint fc = coeff(fi);

            uint icr = fc * rv;
            uint icd = fc * dv;
            a_mu1 += icr;
            a_mu2 += icd;
            a_ref  += uint64_t(icr) * uint64_t(rv);
            a_dis  += uint64_t(icd) * uint64_t(dv);
            a_rd_x += uint64_t(icr) * uint64_t(dv);  /* ref*dis */

            if (fw_rd > 0 && fi >= rd_st && fi < rd_st + fw_rd) {
                uint fc_rd = coeff_rd(fi - rd_st);
                a_ref_rd += fc_rd * rv;
                a_dis_rd += fc_rd * dv;
            }
        }

        int base = r * tile_w + c;
        s_vert[0 * VERT_TOTAL_MAX + base] = (a_mu1 + add_round_vp) >> shift_vp;
        s_vert[1 * VERT_TOTAL_MAX + base] = (a_mu2 + add_round_vp) >> shift_vp;
        if (shift_vp_sq > 0u) {
            s_vert[2 * VERT_TOTAL_MAX + base] = uint((a_ref  + uint64_t(add_round_vp_sq)) >> shift_vp_sq);
            s_vert[3 * VERT_TOTAL_MAX + base] = uint((a_dis  + uint64_t(add_round_vp_sq)) >> shift_vp_sq);
            s_vert[4 * VERT_TOTAL_MAX + base] = uint((a_rd_x + uint64_t(add_round_vp_sq)) >> shift_vp_sq);
        } else {
            s_vert[2 * VERT_TOTAL_MAX + base] = uint(a_ref);
            s_vert[3 * VERT_TOTAL_MAX + base] = uint(a_dis);
            s_vert[4 * VERT_TOTAL_MAX + base] = uint(a_rd_x);
        }
        if (fw_rd > 0) {
            s_vert[5 * VERT_TOTAL_MAX + base] = (a_ref_rd + add_round_vp) >> shift_vp;
            s_vert[6 * VERT_TOTAL_MAX + base] = (a_dis_rd + add_round_vp) >> shift_vp;
        }
    }
    /* Shared-memory release-acquire: pair the cooperative writes to
     * s_vert with Phase-3's per-thread reads. Same Vulkan 1.4 NVIDIA
     * memory-model rationale as the Phase-1 barrier above. */
    memoryBarrierShared();
    barrier();

    /* ============================================================
     * Phase 3: per-thread horizontal conv + VIF stats + downsample.
     * No border handling — the SLM tile already has mirrored halos.
     * ============================================================ */
    int64_t t_x = 0L, t_x2 = 0L, t_num_x = 0L;
    int64_t t_num_log = 0L, t_den_log = 0L;
    int64_t t_num_non_log = 0L, t_den_non_log = 0L;
    uint    h_ref_rd = 0u, h_dis_rd = 0u;

    if (valid) {
        uint h_mu1 = 0u, h_mu2 = 0u;
        uint64_t h_ref = 0UL, h_dis = 0UL, h_ref_dis = 0UL;

        /* Center tap (unpaired). */
        {
            uint fcc = coeff(half_h);
            int  cc  = lx + half_h;
            h_mu1     += fcc * s_vert[0 * VERT_TOTAL_MAX + ly * tile_w + cc];
            h_mu2     += fcc * s_vert[1 * VERT_TOTAL_MAX + ly * tile_w + cc];
            h_ref     += uint64_t(fcc) * uint64_t(s_vert[2 * VERT_TOTAL_MAX + ly * tile_w + cc]);
            h_dis     += uint64_t(fcc) * uint64_t(s_vert[3 * VERT_TOTAL_MAX + ly * tile_w + cc]);
            h_ref_dis += uint64_t(fcc) * uint64_t(s_vert[4 * VERT_TOTAL_MAX + ly * tile_w + cc]);
            if (fw_rd > 0) {
                uint fcc_rd = coeff_rd(HALF_FW_RD());
                h_ref_rd += fcc_rd * s_vert[5 * VERT_TOTAL_MAX + ly * tile_w + cc];
                h_dis_rd += fcc_rd * s_vert[6 * VERT_TOTAL_MAX + ly * tile_w + cc];
            }
        }

        /* Symmetric pairs. */
        for (int fj = 0; fj < half_h; fj++) {
            uint fc = coeff(fj);
            int  lo_c = lx + fj;
            int  hi_c = lx + (fw_h - 1 - fj);
            int  base_lo = ly * tile_w + lo_c;
            int  base_hi = ly * tile_w + hi_c;

            h_mu1 += fc * (s_vert[0 * VERT_TOTAL_MAX + base_lo] + s_vert[0 * VERT_TOTAL_MAX + base_hi]);
            h_mu2 += fc * (s_vert[1 * VERT_TOTAL_MAX + base_lo] + s_vert[1 * VERT_TOTAL_MAX + base_hi]);
            h_ref     += uint64_t(fc) * (uint64_t(s_vert[2 * VERT_TOTAL_MAX + base_lo]) + uint64_t(s_vert[2 * VERT_TOTAL_MAX + base_hi]));
            h_dis     += uint64_t(fc) * (uint64_t(s_vert[3 * VERT_TOTAL_MAX + base_lo]) + uint64_t(s_vert[3 * VERT_TOTAL_MAX + base_hi]));
            h_ref_dis += uint64_t(fc) * (uint64_t(s_vert[4 * VERT_TOTAL_MAX + base_lo]) + uint64_t(s_vert[4 * VERT_TOTAL_MAX + base_hi]));

            if (fw_rd > 0 && fj >= rd_st && fj < rd_st + (fw_rd / 2)) {
                uint fc_rd = coeff_rd(fj - rd_st);
                h_ref_rd += fc_rd * (s_vert[5 * VERT_TOTAL_MAX + base_lo] + s_vert[5 * VERT_TOTAL_MAX + base_hi]);
                h_dis_rd += fc_rd * (s_vert[6 * VERT_TOTAL_MAX + base_lo] + s_vert[6 * VERT_TOTAL_MAX + base_hi]);
            }
        }

        /* Horizontal quantization (shift by 16) — identical to SYCL. */
        uint mu1_val = h_mu1;
        uint mu2_val = h_mu2;
        uint xx_filt = uint((h_ref     + 32768UL) >> 16);
        uint yy_filt = uint((h_dis     + 32768UL) >> 16);
        uint xy_filt = uint((h_ref_dis + 32768UL) >> 16);

        uint mu1_sq   = uint(((uint64_t(mu1_val) * uint64_t(mu1_val)) + 2147483648UL) >> 32);
        uint mu2_sq   = uint(((uint64_t(mu2_val) * uint64_t(mu2_val)) + 2147483648UL) >> 32);
        uint mu1_mu2  = uint(((uint64_t(mu1_val) * uint64_t(mu2_val)) + 2147483648UL) >> 32);

        int sigma1_sq = int(xx_filt - mu1_sq);
        int sigma2_sq = int(yy_filt - mu2_sq);
        int sigma12   = int(xy_filt - mu1_mu2);
        if (sigma1_sq < 0) sigma1_sq = 0;
        if (sigma2_sq < 0) sigma2_sq = 0;

        if (int64_t(sigma1_sq) >= SIGMA_NSQ) {
            /* Promote g / sv_sq / gg_sigma_f to double to match the
             * precision of integer_vif.c's CPU path:
             *   double g = sigma12 / (sigma1_sq + eps);   // eps = 6.5536e-6
             *   int32_t sv_sq = sigma2_sq - g * sigma12;  // double arith, int32 truncation
             *   g = MIN(g, vif_enhn_gain_limit);
             *   int64_t numer1_tmp = (int64_t)(g * g * sigma1_sq) + numer1;
             *
             * The previous `precise float` path (research-0053) blocked FMA
             * contraction but still lost ~7 ULP/pixel vs the CPU's double
             * division, accumulating to ~2e-4 VMAF delta at sub-1080p — above
             * the ADR-0214 places=4 gate (1e-4 threshold).  double eliminates
             * the systematic bias entirely.  The `precise` qualifier is dropped
             * because double arithmetic has no useful FMA contraction in GLSL
             * and GL_EXT_shader_explicit_arithmetic_types_float64 already
             * mandates IEEE-754 double for the promoted variables.
             * Device capability is probed at backend-init time (ADR-0492). */

            /* eps matches integer_vif.c: `const double eps = 65536 * 1.0e-10`
             * The comment there says "this epsilon can go away"; sigma1_sq is
             * >= SIGMA_NSQ (262144) so eps/sigma1_sq < 2.5e-11 — negligible.
             * We include it to stay bit-identical with the C reference. */
            const double EPS = 65536.0lf * 1.0e-10lf;

            double g_d       = 0.0lf;
            int    sv_sq_i   = 0;
            double gg_sigma  = 0.0lf;

            /* Condition mirrors integer_vif.c line 318:
             * `if (sigma12 > 0 && sigma2_sq > 0)`.
             * sigma1_sq > 0 is implied by sigma1_sq >= SIGMA_NSQ above. */
            if (sigma12 > 0 && sigma2_sq > 0) {
                g_d     = double(sigma12) / (double(sigma1_sq) + EPS);
                sv_sq_i = int(double(sigma2_sq) - g_d * double(sigma12));
                if (sv_sq_i < 0) sv_sq_i = 0;
                g_d    = min(g_d, double(pc.vif_enhn_gain_limit));
                gg_sigma = g_d * g_d * double(sigma1_sq);
            }

            uint log_den_stage1 = uint(int64_t(SIGMA_NSQ) + int64_t(sigma1_sq));
            int  x_exp = 0;
            uint log_den1 = dev_best16_from32(log_den_stage1, x_exp);

            t_num_x += 1L;
            t_x     += int64_t(x_exp);

            uint den_val = log2_lut.lut[log_den1 - 32768u];

            if (sigma12 >= 0) {
                uint     numer1 = uint(sv_sq_i) + uint(SIGMA_NSQ);
                uint64_t numer1_tmp = uint64_t(int64_t(gg_sigma)) + uint64_t(numer1);

                int x1 = 0;
                int x2_val = 0;
                uint numlog = dev_best16_from64(numer1_tmp,        x1);
                uint denlog = dev_best16_from64(uint64_t(numer1),  x2_val);

                t_x2 += int64_t(x2_val - x1);

                int num_val = int(log2_lut.lut[numlog - 32768u]) -
                              int(log2_lut.lut[denlog - 32768u]);
                t_num_log += int64_t(num_val);
            }

            t_den_log += int64_t(den_val);
        } else {
            t_num_non_log += int64_t(sigma2_sq);
            t_den_non_log += 1L;
        }
    } /* end if (valid) */

    /* ============================================================
     * Phase 4: subgroup + cross-subgroup reduction.
     * ============================================================ */
    int64_t sg_x        = reduce_i64_subgroup(t_x);
    int64_t sg_x2       = reduce_i64_subgroup(t_x2);
    int64_t sg_num_x    = reduce_i64_subgroup(t_num_x);
    int64_t sg_num_log  = reduce_i64_subgroup(t_num_log);
    int64_t sg_den_log  = reduce_i64_subgroup(t_den_log);
    int64_t sg_num_nlog = reduce_i64_subgroup(t_num_non_log);
    int64_t sg_den_nlog = reduce_i64_subgroup(t_den_non_log);

    uint sg_id     = gl_SubgroupID;
    uint n_subgrps = gl_NumSubgroups;

    if (subgroupElect()) {
        s_lmem[0 * MAX_SUBGROUPS + sg_id] = sg_x;
        s_lmem[1 * MAX_SUBGROUPS + sg_id] = sg_x2;
        s_lmem[2 * MAX_SUBGROUPS + sg_id] = sg_num_x;
        s_lmem[3 * MAX_SUBGROUPS + sg_id] = sg_num_log;
        s_lmem[4 * MAX_SUBGROUPS + sg_id] = sg_den_log;
        s_lmem[5 * MAX_SUBGROUPS + sg_id] = sg_num_nlog;
        s_lmem[6 * MAX_SUBGROUPS + sg_id] = sg_den_nlog;
    }
    /* Shared-memory release-acquire for the cross-subgroup int64
     * reduction. Vulkan 1.4 NVIDIA's stricter default memory model
     * (vs. 1.3) reordered the elected-thread writes to s_lmem past
     * thread-0's reads below — observed empirically as 5-run
     * non-determinism on `den_scale2` magnitudes (10¹¹× off, sign
     * flips) on RTX 4090 + driver 595.71.05 + Vulkan 1.4.341.
     * See research-0089 §"Phase 2 dynamic dump" and the same digest
     * 2026-05-09 Phase 3 status appendix.
     *
     * Phase-3b status (2026-05-09): the workgroup-scope fence pair
     * below closes Arc A380 + Mesa-ANV and RADV at API 1.4 (0/48,
     * 5-run deterministic). NVIDIA RTX 4090 + driver 595.71.05 +
     * API 1.4 still exhibits the same 45/48 scale-2 non-determinism
     * even with stronger fences (subgroup-scope shared-memory fence,
     * device-scope `controlBarrier`, and both stacked were tested in
     * PR #N; numbers in research-0090 + ADR-0269 status update).
     * Tracked as `T-VK-VIF-1.4-RESIDUAL-NVIDIA-DEFERRED`; the
     * shipping default is API 1.3 where the gate is 0/48 on every
     * device. */
    memoryBarrierShared();
    barrier();

    /* Thread 0 of the workgroup writes the per-WG accumulator slot.
     * No atomicAdd needed — every workgroup owns its own row in
     * accum_out.v. The host CPU sums the rows after the dispatch. */
    if (lid == 0u) {
        int64_t f0 = 0L, f1 = 0L, f2 = 0L, f3 = 0L, f4 = 0L, f5 = 0L, f6 = 0L;
        for (uint s = 0u; s < n_subgrps; s++) {
            f0 += s_lmem[0 * MAX_SUBGROUPS + s];
            f1 += s_lmem[1 * MAX_SUBGROUPS + s];
            f2 += s_lmem[2 * MAX_SUBGROUPS + s];
            f3 += s_lmem[3 * MAX_SUBGROUPS + s];
            f4 += s_lmem[4 * MAX_SUBGROUPS + s];
            f5 += s_lmem[5 * MAX_SUBGROUPS + s];
            f6 += s_lmem[6 * MAX_SUBGROUPS + s];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        uint base   = wg_idx * uint(ACCUM_FIELDS);
        accum_out.v[base + 0u] = f0;
        accum_out.v[base + 1u] = f1;
        accum_out.v[base + 2u] = f2;
        accum_out.v[base + 3u] = f3;
        accum_out.v[base + 4u] = f4;
        accum_out.v[base + 5u] = f5;
        accum_out.v[base + 6u] = f6;
    }

    /* ============================================================
     * Downsample for next scale: even-coord threads only.
     * ============================================================ */
    if (fw_rd > 0 && valid && (gx & 1) == 0 && (gy & 1) == 0) {
        uint ref_rd_v = (h_ref_rd + 32768u) >> 16;
        uint dis_rd_v = (h_dis_rd + 32768u) >> 16;
        uint rd_x = uint(gx) >> 1;
        uint rd_y = uint(gy) >> 1;
        uint rd_stride = pc.width >> 1;
        rd_ref_out.rd[rd_y * rd_stride + rd_x] = ref_rd_v & 0xFFFFu;
        rd_dis_out.rd[rd_y * rd_stride + rd_x] = dis_rd_v & 0xFFFFu;
    }
}
