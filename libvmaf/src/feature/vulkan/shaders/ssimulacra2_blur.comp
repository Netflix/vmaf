 *
 * Vulkan compute shader for the ssimulacra2 separable FastGaussian
 * IIR blur (T7-23 / GPU long-tail batch 3 part 7 / ADR-0200).
 * Mirrors fast_gaussian_1d / blur_plane in
 * libvmaf/src/feature/ssimulacra2.c — Charalampidis 2016 3-pole
 * recursive Gaussian with k = {1, 3, 5}, sigma=1.5, zero-padded
 * boundaries (matches libjxl gauss_blur.cc).
 *
 * The IIR is sequential along the scan axis. We exploit the
 * "rows independent for H-pass, columns independent for V-pass"
 * separability:
 *   PASS = 0  (horizontal): one workgroup per row.
 *                           local_size_x = 1, dispatch (1, H, 1).
 *                           Single thread per row scans left→right.
 *   PASS = 1  (vertical):   one workgroup per column.
 *                           local_size_x = 1, dispatch (1, W, 1).
 *                           Single thread per column scans top→bottom.
 *
 * This is correctness-first; performance follow-ups can re-bin
 * multiple rows/cols per WG once the places-2 contract holds.
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH   (per-scale W)
 *   constant_id = 1  HEIGHT  (per-scale H)
 *   constant_id = 2  PASS    (0 = horizontal, 1 = vertical)
 */
#version 460

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;
layout(constant_id = 2) const int PASS   = 0;

layout(set = 0, binding = 0, std430) readonly buffer InBuf  { float v[]; } in_buf;
layout(set = 0, binding = 1, std430)          buffer OutBuf { float v[]; } out_buf;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    /* IIR coefficients: 3 poles k = {1, 3, 5}. */
    float n2_0;
    float n2_1;
    float n2_2;
    float d1_0;
    float d1_1;
    float d1_2;
    int   radius;
    uint  in_offset;  /* element offset added to every input read (= channel offset in 3-plane buffer) */
    uint  out_offset; /* element offset added to every output write */
} pc;

/* `precise` on the IIR state + per-step intermediates blocks the
 * SPIR-V/driver compiler from FMA-contracting
 *   o = n2 * sum - d1 * prev1 - prev2
 * The CPU port writes this expression with separate FMUL/FSUB ops
 * under -O2 without -mfma; the GPU MUST match the same order or
 * the IIR's pole-tracking error compounds across the radius + the
 * 6-scale pyramid into the 1.5e-2 range we measured pre-fix.
 *
 * Each `o_k` is computed as `(n2_k * sum) - (d1_k * prev1_k) - prev2_k`
 * with explicit temporaries so the SPIR-V output is
 *   FMul, FMul, FSub, FSub
 * instead of `OpExtInst Fma` (which produces a different rounding
 * step on lavapipe and most hardware ICDs).
 */
void main_horiz(uint row) {
    if (row >= pc.height) return;
    int xsize = int(pc.width);
    int N = pc.radius;

    precise float prev1_0 = 0.0, prev1_1 = 0.0, prev1_2 = 0.0;
    precise float prev2_0 = 0.0, prev2_1 = 0.0, prev2_2 = 0.0;

    uint in_base  = pc.in_offset  + row * pc.width;
    uint out_base = pc.out_offset + row * pc.width;
    for (int n = -N + 1; n < xsize; ++n) {
        int left  = n - N - 1;
        int right = n + N - 1;
        precise float lv = (left  >= 0)     ? in_buf.v[in_base + uint(left)]  : 0.0;
        precise float rv = (right < xsize)  ? in_buf.v[in_base + uint(right)] : 0.0;
        precise float sum = lv + rv;

        /* Match CPU expression `n2*sum - d1*prev1 - prev2` ordering. */
        precise float ns0 = pc.n2_0 * sum;
        precise float dp0 = pc.d1_0 * prev1_0;
        precise float t0  = ns0 - dp0;
        precise float o0  = t0 - prev2_0;
        precise float ns1 = pc.n2_1 * sum;
        precise float dp1 = pc.d1_1 * prev1_1;
        precise float t1  = ns1 - dp1;
        precise float o1  = t1 - prev2_1;
        precise float ns2 = pc.n2_2 * sum;
        precise float dp2 = pc.d1_2 * prev1_2;
        precise float t2  = ns2 - dp2;
        precise float o2  = t2 - prev2_2;
        prev2_0 = prev1_0; prev2_1 = prev1_1; prev2_2 = prev1_2;
        prev1_0 = o0;      prev1_1 = o1;      prev1_2 = o2;

        if (n >= 0) {
            precise float s01 = o0 + o1;
            precise float s_total = s01 + o2;
            out_buf.v[out_base + uint(n)] = s_total;
        }
    }
}

void main_vert(uint col) {
    if (col >= pc.width) return;
    int ysize = int(pc.height);
    uint W = pc.width;
    int N = pc.radius;

    precise float prev1_0 = 0.0, prev1_1 = 0.0, prev1_2 = 0.0;
    precise float prev2_0 = 0.0, prev2_1 = 0.0, prev2_2 = 0.0;

    for (int n = -N + 1; n < ysize; ++n) {
        int left  = n - N - 1;
        int right = n + N - 1;
        precise float lv = (left  >= 0)     ? in_buf.v[pc.in_offset  + uint(left)  * W + col] : 0.0;
        precise float rv = (right < ysize)  ? in_buf.v[pc.in_offset  + uint(right) * W + col] : 0.0;
        precise float sum = lv + rv;

        precise float ns0 = pc.n2_0 * sum;
        precise float dp0 = pc.d1_0 * prev1_0;
        precise float t0  = ns0 - dp0;
        precise float o0  = t0 - prev2_0;
        precise float ns1 = pc.n2_1 * sum;
        precise float dp1 = pc.d1_1 * prev1_1;
        precise float t1  = ns1 - dp1;
        precise float o1  = t1 - prev2_1;
        precise float ns2 = pc.n2_2 * sum;
        precise float dp2 = pc.d1_2 * prev1_2;
        precise float t2  = ns2 - dp2;
        precise float o2  = t2 - prev2_2;
        prev2_0 = prev1_0; prev2_1 = prev1_1; prev2_2 = prev1_2;
        prev1_0 = o0;      prev1_1 = o1;      prev1_2 = o2;

        if (n >= 0) {
            precise float s01 = o0 + o1;
            precise float s_total = s01 + o2;
            out_buf.v[pc.out_offset + uint(n) * W + col] = s_total;
        }
    }
}

void main() {
    /* Each workgroup processes one row (H-pass) or one column
     * (V-pass). The dispatcher passes the scan-line index in
     * gl_WorkGroupID.y for H-pass and gl_WorkGroupID.y for V-pass
     * (so we only need 1D dispatch with .y as the line). */
    uint line = gl_WorkGroupID.y;
    if (PASS == 0) {
        main_horiz(line);
    } else {
        main_vert(line);
    }
}
