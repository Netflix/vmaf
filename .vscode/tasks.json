{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "meson: setup CPU",
      "type": "shell",
      "command": "meson setup build libvmaf -Denable_cuda=false -Denable_sycl=false --buildtype=debug",
      "problemMatcher": ["$gcc"],
      "group": "build"
    },
    {
      "label": "meson: setup CUDA",
      "type": "shell",
      "command": "meson setup build libvmaf -Denable_cuda=true -Denable_sycl=false --buildtype=debug --reconfigure",
      "problemMatcher": ["$gcc"],
      "group": "build"
    },
    {
      "label": "meson: setup SYCL",
      "type": "shell",
      "command": "meson setup build libvmaf -Denable_cuda=false -Denable_sycl=true --buildtype=debug --reconfigure",
      "problemMatcher": ["$gcc"],
      "group": "build"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "meson compile -C build",
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "test: unit",
      "type": "shell",
      "command": "meson test -C build --print-errorlogs",
      "problemMatcher": [],
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "test: netflix-golden",
      "type": "shell",
      "command": "make test-netflix-golden",
      "problemMatcher": []
    },
    {
      "label": "lint: all",
      "type": "shell",
      "command": "make lint",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "format: all",
      "type": "shell",
      "command": "make format",
      "problemMatcher": []
    }
  ]
}
