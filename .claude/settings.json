{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "permissions": {
    "allow": [
      "Bash(meson setup:*)",
      "Bash(meson compile:*)",
      "Bash(meson test:*)",
      "Bash(meson configure:*)",
      "Bash(meson introspect:*)",
      "Bash(ninja:*)",
      "Bash(pkg-config:*)",
      "Bash(nasm:*)",
      "Bash(make:*)",

      "Bash(clang:*)",
      "Bash(gcc:*)",
      "Bash(g++:*)",
      "Bash(clang++:*)",
      "Bash(clang-format:*)",
      "Bash(clang-tidy:*)",
      "Bash(cppcheck:*)",
      "Bash(iwyu_tool:*)",
      "Bash(include-what-you-use:*)",
      "Bash(scan-build:*)",

      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(tox:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",

      "Bash(semgrep:*)",
      "Bash(gitleaks:*)",
      "Bash(trivy:*)",
      "Bash(cosign:*)",
      "Bash(cyclonedx-cli:*)",
      "Bash(syft:*)",
      "Bash(release-please:*)",

      "Bash(nvidia-smi:*)",
      "Bash(cuda-gdb:*)",
      "Bash(nvprof:*)",
      "Bash(nsys:*)",
      "Bash(ncu:*)",
      "Bash(rocminfo:*)",
      "Bash(rocprof:*)",
      "Bash(sycl-ls:*)",
      "Bash(icpx:*)",
      "Bash(clang++ -fsycl:*)",

      "Bash(build/tools/vmaf:*)",
      "Bash(build/tools/vmaf_bench:*)",
      "Bash(build/test/*)",
      "Bash(./build/tools/vmaf:*)",
      "Bash(./build/tools/vmaf_bench:*)",
      "Bash(./build/test/*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git reset --mixed:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git bisect:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh release:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",

      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(jq:*)",
      "Bash(ldconfig:*)",
      "Bash(ulimit:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(objdump:*)",
      "Bash(nm:*)",
      "Bash(readelf:*)",
      "Bash(perf:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease origin master:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git reset --hard origin/master:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ..:*)",
      "Bash(rm -rf .git:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "command": ".claude/hooks/block-unsafe-bash.sh" }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write", "command": ".claude/hooks/auto-format-on-edit.sh" },
      { "matcher": "Edit|Write", "command": ".claude/hooks/auto-snapshot-warn.sh" },
      { "matcher": "Edit|Write", "command": ".claude/hooks/compile-commands-sync.sh" }
    ],
    "SessionStart": [
      { "command": ".claude/hooks/session-start.sh" }
    ],
    "Stop": [
      { "command": ".claude/hooks/stop.sh" }
    ]
  }
}
